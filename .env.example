# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# Database
ConnectionStrings__DefaultConnection=Data Source=aluraProject.db

# JWT
Jwt__Issuer=aluraProject
Jwt__Audience=aluraProject.Client
Jwt__Key=change-this-with-a-strong-secret-with-16-plus-chars
Jwt__AccessTokenMinutes=120

# Seed (optional, idempotent)
Seed__Admin__Email=admin@aluraproject.local
Seed__Admin__Password=change-this-admin-password

# CORS (optional)
Cors__AllowedOrigins__0=https://localhost:3000
Cors__AllowedOrigins__1=http://localhost:3000
